# n8n instance
# Quick start: copy to .env, then run `npm start` (macOS / Windows / Linux).
# Windows encryption key: -join ((1..32 | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) }))
# macOS/Linux encryption key: openssl rand -hex 32
# Optional: override auto-detected Docker container name (default: compose service "n8n" for this repo)
# N8N_CONTAINER=n8n-flow-v11-n8n-1
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_PUBLIC_URL=http://localhost:5678
N8N_INTERNAL_URL=http://n8n:5678
GENERIC_TIMEZONE=America/New_York

# Webhook URLs (host scripts — defaults derived from N8N_PUBLIC_URL if unset)
RAG_WEBHOOK_URL=
CRR_WEBHOOK_URL=
RAG_TELEGRAM_WEBHOOK_URL=

# Docker sidecar webhooks (defaults derived from N8N_INTERNAL_URL if unset)
N8N_INGEST_WEBHOOK=
N8N_TELEGRAM_WEBHOOK=
N8N_TELEGRAM_WEBHOOK_RAG=
N8N_TELEGRAM_WEBHOOK_REVIEW=
N8N_TELEGRAM_WEBHOOK_BOOKING=
N8N_TELEGRAM_WEBHOOK_MARKETING=
N8N_TELEGRAM_WEBHOOK_PORTFOLIO=
N8N_TELEGRAM_WEBHOOK_RESUME=

# Appointment Booking Agent
APPOINTMENT_REMINDER_HOURS=24

# Brand defaults
BRAND_NAME=VGI Skill Universe!
# Optional Telegram welcome overrides (use \n for line breaks)
TELEGRAM_WELCOME_TEXT=
TELEGRAM_RAG_WELCOME=
BRAND_VOICE=Professional, clear, and helpful. Avoid hype and jargon.
TARGET_AUDIENCE=Business professionals
BRAND_WEBSITE=https://example.com
DEFAULT_CTA=Book a demo

# AI provider: openai (direct) or openrouter
AI_PROVIDER=openai

# OpenAI (primary — chat, embeddings, vision)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_SPECIALIST=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OCR_VISION_MODEL=gpt-4o-mini

# OpenRouter (optional fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL=
MAX_PDF_OCR_IMAGES=25
PDF_OCR_MAX_TOKENS=700

# Qdrant vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Telegram — shared multi-workflow bot (RAG, Review, Booking, Marketing, Portfolio, Resume)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional dedicated bots (create each via @BotFather; leave blank to skip)
TELEGRAM_BOT_TOKEN_RAG=
TELEGRAM_BOT_TOKEN_REVIEW=
TELEGRAM_BOT_TOKEN_BOOKING=
TELEGRAM_BOT_TOKEN_MARKETING=
TELEGRAM_BOT_TOKEN_PORTFOLIO=
TELEGRAM_BOT_TOKEN_RESUME=
TELEGRAM_BOT_TOKEN_HR=
# Standalone Drive Q&A bot — users connect their own Google Drive folder
TELEGRAM_BOT_TOKEN_DRIVE_RAG=
TELEGRAM_DRIVE_RAG_WELCOME=
# Leave empty for a public HR bot. Set to one chat id to restrict access.
TELEGRAM_CHAT_ID_HR=
N8N_TELEGRAM_WEBHOOK_HR=
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_WEBHOOK_TIMEOUT_MS=300000
TELEGRAM_RESUME_TIMEOUT_MS=600000

# Portfolio report APIs (optional; workflow has sample defaults)
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
MARKETAUX_API_KEY=
PORTFOLIO_NAME=My Portfolio
RESUMES_FOLDER=/files/resumes

# Email / SMTP
EMAIL_FROM=your-email@example.com
EMAIL_TO=your-inbox@example.com
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password-here

# Customer Review Responder — Serper.dev (optional; Reddit works without it)
SERPER_API_KEY=your-serper-key

# Google Drive auto-ingest
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/your-folder-id
GOOGLE_SERVICE_ACCOUNT_FILE=/data/service-account-key.json
GOOGLE_DRIVE_POLL_INTERVAL_SECONDS=30
GOOGLE_DRIVE_RECURSIVE=true

# Optional: Slack error alerts
SLACK_ALERT_CHANNEL_ID=C0000000000
ENABLE_SLACK=false

# n8n encryption (generate: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string
